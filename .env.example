# HTTP server
PORT=3000

# ThingsBoard Cloud credentials (EU Cloud)
TB_HOST=eu.thingsboard.cloud
TB_TOKEN_BOILER=YOUR_BOILER_TOKEN
TB_TOKEN_MOTOR=YOUR_MOTOR_TOKEN
TB_TOKEN_CONVEYOR=YOUR_CONVEYOR_TOKEN
TB_TOKEN_PUMP=YOUR_PUMP_TOKEN

# Simulation Settings
UPDATE_INTERVAL_MS=5000
# Probability of an anomaly occurring per update (0.1 = 10%)
ANOMALY_PROBABILITY=0.1

# MCP Server Settings
MCP_SERVER_NAME=industrial-copilot
MCP_SERVER_VERSION=1.0.0
